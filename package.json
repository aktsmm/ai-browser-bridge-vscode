{
  "name": "copilot-browser-bridge-vscode",
  "displayName": "AI Browser Bridge",
  "description": "ブラウザのページ内容をAIで解析・対話。GitHub Copilot またはローカルLLMと連携。",
  "version": "0.1.20",
  "publisher": "yamapan",
  "keywords": [
    "browser",
    "ai",
    "llm",
    "copilot",
    "github copilot",
    "local llm",
    "lm studio",
    "page analysis",
    "automation",
    "bridge",
    "side panel",
    "web"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/aktsmm/copilot-browser-bridge-vscode"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "copilotBrowserBridge.startServer",
        "title": "AI Browser Bridge: Start Server"
      },
      {
        "command": "copilotBrowserBridge.stopServer",
        "title": "AI Browser Bridge: Stop Server"
      }
    ],
    "configuration": {
      "title": "AI Browser Bridge",
      "properties": {
        "copilotBrowserBridge.serverPort": {
          "type": "number",
          "default": 3210,
          "description": "Port for the localhost server"
        },
        "copilotBrowserBridge.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start server on VS Code startup"
        },
        "copilotBrowserBridge.enableAgentTerminalTool": {
          "type": "boolean",
          "default": false,
          "description": "Allow a small read-only subset of copilot-agent terminal commands"
        },
        "copilotBrowserBridge.enableCopilotCliFallback": {
          "type": "boolean",
          "default": true,
          "description": "Allow GitHub Copilot CLI to be used as a fallback when VS Code language model access is unavailable"
        },
        "copilotBrowserBridge.allowedExtensionOrigins": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional allowed chrome-extension:// origins (official store origin is always allowed)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "test": "vitest run",
    "watch": "tsc -watch -p ./",
    "lint": "eslint \"src/**/*.ts\" --max-warnings=0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "eslint": "^9.26.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  },
  "license": "CC-BY-NC-SA-4.0",
  "icon": "media/icon.png",
  "dependencies": {
    "@github/copilot-sdk": "^1.0.0-beta.9"
  }
}
